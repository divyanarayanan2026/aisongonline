# Required — get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional — for professional AI voice synthesis (ElevenLabs)
# Without this, the app uses your browser's built-in text-to-speech
# Get a free key at https://elevenlabs.io
ELEVENLABS_API_KEY=

# Server port (default: 3000)
PORT=3000
